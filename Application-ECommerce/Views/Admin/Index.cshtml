@model Application_ECommerce.App.Dashboard.Dtos.DashboardStatsDto
@{
    ViewData["Title"] = "Tableau de Bord Administrateur";
}

<link rel="stylesheet" href="~/css/dashboard.css" />

<div class="dashboard-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">Tableau de bord <span class="text-muted fw-light">| Aperçu global</span></h1>
        <div class="text-muted">@DateTime.Now.ToString("dd MMMM yyyy")</div>
    </div>

    <!-- KPI Cards -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="kpi-card">
                <div class="kpi-icon bg-primary-grad">
                    <i class="bi bi-currency-dollar"></i>
                </div>
                <div>
                    <div class="text-muted small">Ventes Totales</div>
                    <div class="h4 mb-0">@Model.TotalSales.ToString("C2")</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi-card">
                <div class="kpi-icon bg-secondary-grad">
                    <i class="bi bi-cart-check"></i>
                </div>
                <div>
                    <div class="text-muted small">Commandes</div>
                    <div class="h4 mb-0">@Model.TotalOrders</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi-card">
                <div class="kpi-icon bg-accent-grad">
                    <i class="bi bi-box-seam"></i>
                </div>
                <div>
                    <div class="text-muted small">Produits</div>
                    <div class="h4 mb-0">@Model.TotalProducts</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi-card">
                <div class="kpi-icon bg-info-grad">
                    <i class="bi bi-people"></i>
                </div>
                <div>
                    <div class="text-muted small">Clients</div>
                    <div class="h4 mb-0">@Model.TotalCustomers</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row g-4 mb-5">
        <div class="col-lg-8">
            <div class="chart-card">
                <h5 class="mb-4">Croissance des revenus (6 derniers mois)</h5>
                <canvas id="salesChart" height="120"></canvas>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="chart-card">
                <h5 class="mb-4">État des commandes</h5>
                <canvas id="statusChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Recent Orders Table -->
    <div class="table-card">
        <div class="p-4 d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Commandes récentes</h5>
            <a asp-controller="Order" asp-action="OrderIndex" class="btn btn-sm btn-outline-primary shadow-sm">Voir tout</a>
        </div>
        <div class="table-responsive">
            <table class="table custom-table mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">ID Commande</th>
                        <th>Client</th>
                        <th>Date</th>
                        <th>Total</th>
                        <th>Statut</th>
                        <th class="pe-4 text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.RecentOrders)
                    {
                        <tr>
                            <td class="ps-4 fw-medium">#@order.Id.ToString().Substring(0, 8)</td>
                            <td>@order.Name</td>
                            <td>@order.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@order.OrderTotal?.ToString("C2")</td>
                            <td>
                                <span class="status-badge status-@(order.Status.ToLower())">
                                    @order.Status
                                </span>
                            </td>
                            <td class="pe-4 text-end">
                                <a asp-controller="Order" asp-action="OrderDetails" asp-route-orderId="@order.Id" class="btn btn-link py-0 px-2">
                                    <i class="bi bi-eye text-primary"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        $(document).ready(function() {
            $.get("/Admin/GetSalesData", function(data) {
                // Sales Chart
                const salesCtx = document.getElementById('salesChart').getContext('2d');
                const salesLabels = Object.keys(data.salesByMonth);
                const salesValues = Object.values(data.salesByMonth);

                new Chart(salesCtx, {
                    type: 'line',
                    data: {
                        labels: salesLabels,
                        datasets: [{
                            label: 'Revenus (€)',
                            data: salesValues,
                            borderColor: '#6366f1',
                            backgroundColor: 'rgba(99, 102, 241, 0.1)',
                            fill: true,
                            tension: 0.4,
                            pointRadius: 4,
                            pointBackgroundColor: '#fff',
                            pointBorderColor: '#6366f1'
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { display: false }
                        },
                        scales: {
                            y: { beginAtZero: true, grid: { color: '#f1f5f9' } },
                            x: { grid: { display: false } }
                        }
                    }
                });

                // Status Chart
                const statusCtx = document.getElementById('statusChart').getContext('2d');
                const statusLabels = Object.keys(data.ordersByStatus);
                const statusValues = Object.values(data.ordersByStatus);

                new Chart(statusCtx, {
                    type: 'doughnut',
                    data: {
                        labels: statusLabels,
                        datasets: [{
                            data: statusValues,
                            backgroundColor: [
                                '#f59e0b', // Pending
                                '#10b981', // Shipped
                                '#ef4444', // Cancelled
                                '#3b82f6', // Other
                                '#6366f1'
                            ],
                            borderWidth: 0
                        }]
                    },
                    options: {
                        responsive: true,
                        cutout: '70%',
                        plugins: {
                            legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20 } }
                        }
                    }
                });
            });
        });
    </script>
}
